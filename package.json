{
  "name": "powershell-inline-eval",
  "displayName": "PowerShell Inline Eval",
  "description": "Evaluate PowerShell inline in VS Code with a persistent session, structured previews, and output channel fallback.",
  "version": "0.0.1",
  "publisher": "srejv",
  "license": "MIT",
  "markdown": "github",
  "repository": {
    "type": "git",
    "url": "https://github.com/srejv/powershell-inline-eval.git"
  },
  "homepage": "https://github.com/srejv/powershell-inline-eval#readme",
  "bugs": {
    "url": "https://github.com/srejv/powershell-inline-eval/issues"
  },
  "keywords": [
    "powershell",
    "pwsh",
    "inline",
    "evaluation",
    "repl",
    "scripting",
    "terminal"
  ],
  "galleryBanner": {
    "color": "#103b52",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "powershellContext.evaluateLine",
        "title": "Evaluate Current PowerShell Line",
        "category": "PowerShell Inline Eval"
      },
      {
        "command": "powershellContext.evaluateSelection",
        "title": "Evaluate PowerShell Selection",
        "category": "PowerShell Inline Eval"
      },
      {
        "command": "powershellContext.evaluateFile",
        "title": "Evaluate PowerShell File",
        "category": "PowerShell Inline Eval"
      },
      {
        "command": "powershellContext.restartSession",
        "title": "Restart PowerShell Session",
        "category": "PowerShell Inline Eval"
      },
      {
        "command": "powershellContext.showSessionInfo",
        "title": "Show PowerShell Session Info",
        "category": "PowerShell Inline Eval"
      },
      {
        "command": "powershellContext.clearInlineResult",
        "title": "Clear Inline PowerShell Result",
        "category": "PowerShell Inline Eval"
      },
      {
        "command": "powershellContext.showLastResultPreview",
        "title": "Show Last PowerShell Result Preview",
        "category": "PowerShell Inline Eval"
      }
    ],
    "keybindings": [
      {
        "command": "powershellContext.evaluateLine",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && editorLangId == powershell"
      },
      {
        "command": "powershellContext.evaluateSelection",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && editorLangId == powershell && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "PowerShell Inline Eval",
      "properties": {
        "powershellContext.preview.inlineMaxLength": {
          "type": "number",
          "default": 72,
          "minimum": 16,
          "description": "Maximum length of the inline preview before it is shortened."
        },
        "powershellContext.preview.itemLimit": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of object properties or collection items included in structured previews."
        },
        "powershellContext.preview.depth": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 3,
          "description": "Maximum nesting depth used for structured object previews."
        },
        "powershellContext.previewPanel.autoOpen": {
          "type": "string",
          "enum": ["never", "structured", "expandedOutput", "always"],
          "default": "structured",
          "markdownDescription": "When the dedicated result preview panel should open automatically. `structured` opens it for object, dictionary, and collection results."
        },
        "powershellContext.outputChannel.autoOpen": {
          "type": "string",
          "enum": ["never", "errors", "expandedOutput", "always"],
          "default": "errors",
          "markdownDescription": "When the output channel should open automatically. `expandedOutput` opens it when the inline preview was shortened."
        },
        "powershellContext.powerShellExecutable": {
          "type": "string",
          "enum": ["auto", "pwsh", "powershell"],
          "default": "auto",
          "markdownDescription": "Choose which PowerShell executable the extension uses. `pwsh` targets PowerShell 7+, `powershell` targets Windows PowerShell 5.1, and `auto` prefers `pwsh` with fallback to `powershell`."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src test --ext .ts",
    "vscode:prepublish": "npm run compile",
    "pretest": "npm run compile && npm run lint",
    "test": "npm run test:unit && npm run test:extension",
    "test:unit": "mocha \"out/test/unit/**/*.test.js\"",
    "test:extension": "node ./out/test/extension/runTest.js",
    "package:vsix": "vsce package --allow-missing-repository",
    "publish:vsce": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "mocha": "^11.2.2",
    "typescript": "^5.8.3"
  }
}
